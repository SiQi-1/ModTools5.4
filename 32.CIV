        "diplomacy": []
      },
      {
        "name": "魈",
        "abbr": "5",
        "type": "LEADER_SIQI_L0032_5",
        "leader_name": "魈",
        "sex": "Male",
        "capital_name": "璃月港",
        "civilization_type": "CIVILIZATION_SIQI_C0032_1",
        "civilization_name": "璃月",
        "leader_text": "在璃月港住民心中，居于「绝云间」的「三眼五显仙人」，皆有极高名望。[NEWLINE]每逢佳节吉日，人们都会上香祷告，祈望仙人保佑。[NEWLINE]但人们不会对魈祈祷。[NEWLINE]因为魈并不是能带来祥瑞、富贵的福星，而是与妖邪死斗的「夜叉」。[NEWLINE]在璃月港千家万户通明的灯火后，这些战斗既无尽头，也无胜者。无人见证，也无人感激。[NEWLINE]魈并不在意，因为他是璃月的护法夜叉，守护璃月是他必须履行的「契约」。",
        "leader_quote": "靖妖傩舞",
        "ability_name": "护法夜叉大将",
        "ability_description": "为所有政体提供1个军事槽位与1个通用槽位。开局解锁科技“占星术”。所有军事单位与蛮族战斗时+15力且击败蛮族后有大概率（80%）将该蛮族转换为建造者。拥有军营的城市可以使用信仰购买军事单位，若拥有骑士长礼拜堂则-50%消耗与战略资源；有总督就任的城市新训练与购买的单位可以在该回合立刻行动并+3移动力。同时拥有军营与总督的城市，新训练的军事单位额外获得一次晋升。所有军事单位晋升不会结束回合。军营中每一级建筑，为商路+5生产力。",
        "select_sort_index": 32,
        "add_diplo_background_curtain": true,
        "icon_image_name": "ICON_LEADER_SIQI_L0032_5",
        "foreground_image_name": "LEADER_SIQI_L0032_5_NEUTRAL",
