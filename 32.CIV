        "promotions": {
          "base": {
            "enabled": true,
            "name": "岩王帝君",
            "description": "所有类型的丘陵单元格+2生产力与2金币。有奢侈品资源的单元格额外+2信仰。"
          },
          "tiers": [
            [
              {
                "enabled": true,
                "name": "贵金之神",
                "description": "矿山与采石场+1生产力与3金币。城市内每有一种资源为城市+1%的金币。"
              },
              {
                "enabled": false,
                "name": "",
                "description": ""
              },
              {
                "enabled": true,
                "name": "璃月的武神",
                "description": "拥有4/7/10点人口的城市，所有区域+2生产力与信仰/购买军事单位花费-30%/新训练的近战与抗骑兵单位+8力与3移动力，且无视地形地貌与河流的移动力惩罚。"
              }
            ],
            [
              {
                "enabled": true,
                "name": "契约的保护者",
                "description": "从城邦征兵时-75%消耗并为该城邦添加3名使者。若本城拥有市政广场，则从宗主的城邦获得+2对应的产出。"
              },
              {
                "enabled": false,
                "name": "",
                "description": ""
              },
              {
                "enabled": true,
                "name": "岩之魔神",
                "description": "所有军事单位从每个相邻的丘陵单元格+5力。单位于丘陵单元格回合开始时，+3视野与2移动力。"
              }
            ],
            [
              {
                "enabled": false,
                "name": "",
                "description": ""
              },
              {
                "enabled": true,
                "name": "岩间琉璃云间月",
                "description": "所有城市+2宜居度。若文明未处于黄金时代/处于黄金时代，则所有城市+5%金币与文化值/+15%文化值且每点溢出的忠诚度转变为等量的文化值。"
              },
              {
                "enabled": false,
                "name": "",
                "description": ""
              }
            ]
          ]
        }
      }
    ],
