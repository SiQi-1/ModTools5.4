    "总督": [
      {
        "name": "兹白",
        "code": "1",
        "GovernorType": "GOVERNOR_SIQI_G0032_1",
        "Name": "兹白",
        "Description": "几乎无人知晓的是，在璃月流传的白马仙人轶闻，竟然是从这位仙人的陨灭开始。她本是高天的使者，在数千年前为指引凡人而降世。她庇护着盛产晶砂与珠玉的古国琅玕，授人稼穑织纴，使国民五谷丰登，仓廪富足。",
        "Title": "白马仙人",
        "ShortTitle": "白马仙人",
        "IdentityPressure": 8,
        "TransitionStrength": 250,
        "AssignCityState": 0,
        "TraitType": "TRAIT_GOVERNOR_SIQI_G0032_1",
