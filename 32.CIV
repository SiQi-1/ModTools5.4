        "name": "璃月",
        "abbr": "1",
        "type": "CIVILIZATION_SIQI_C0032_1",
        "civilization_name": "璃月",
        "civilization_description": "璃月帝国",
        "civilization_adjective": "璃月的",
        "description_suffix": "帝国",
