    "领袖": [
      {
        "name": "丰川祥子",
        "abbr": "OBLIVIONIS",
        "type": "LEADER_SIQI_OBLIVIONIS",
        "leader_name": "丰川祥子",
        "sex": "Female",
        "capital_name": "遗忘",
        "civilization_type": "CIVILIZATION_SIQI_AVEMUJICA",
        "civilization_name": "Ave Mujica",
        "leader_text": "Ave Mujica的键盘手丰川祥子。与其他成员一起暂居罗德岛，在此期间，积极参与舰上的各项工作。不管是音乐上的造诣，还是行为礼仪，都彰显了她不折不扣的名门大小姐身份。",
        "leader_quote": "她会一步一步成长，丢掉自己的幼稚和软弱，成长为一位能肩负起同伴一生的人。",
        "ability_name": "毋畏遗忘",
        "ability_description": "攻击造成伤害时，+3fever。所有军事单位回合开始时，若是位于国内，则地块+1文化，若位于中立领土，则+3经验。若是位于敌方领土，自动对周围敌方单位/城市造成固定10点伤害。城市允许消耗地块所有文化产出，提供大量生产力。",
        "select_sort_index": 19,
        "add_diplo_background_curtain": true,
        "icon_image_name": "ICON_LEADER_SIQI_OBLIVIONIS",
