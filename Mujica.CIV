        "ethnicity": "ETHNICITY_ASIAN",
        "city_name_depth": 10,
        "trait_name": "fever",
        "trait_description": "Ave Mujica成员作为领袖时，其他四位将作为特色总督登场。修建舞会演出厅后，解锁演出面板，各特色总督可以于此进行演出，获得各自的特色效果。解锁科技/市政时立即获得+10fever，fever到达450时，可以主动触发fever时刻，所有特色总督开始演出，持续10回合。fever期间，所有城市+6宜居度，旅游业绩+100%，立即获得4个总督头衔。",
        "trait_bindings": [
          {
            "section": "区域",
            "category_label": "区域",
            "name": "舞会演出厅",
            "type": "DISTRICT_SIQI_BALLROOM",
