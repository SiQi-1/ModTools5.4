        "promotions": {
          "base": {
            "enabled": true,
            "name": "琅玕的社稷神",
            "description": "本城+30%粮食，其余城市+15%粮食。所有城市额外获得一个区域位。若文明未处于黄金时代/处于黄金时代，则建造者+3劳动力/+3移动力。建造者改良农场时触发文化炸弹。帝国内的所有加成资源额外+2信仰。"
          },
          "tiers": [
            [
              {
                "enabled": true,
                "name": "后土为社",
                "description": "本城所有单元格+3魅力，其余城市+2魅力。若城市拥有区域“保护区”则所有地块+1粮食与2生产力。"
              },
              {
                "enabled": false,
                "name": "",
                "description": ""
              },
              {
                "enabled": true,
                "name": "五谷为稷",
                "description": "城市内每改良一个加成资源则为城市+1%粮食与生产力。解锁建造者可以于符合规则的单元格生成加成资源。"
              }
            ],
            [
              {
                "enabled": true,
                "name": "忝为社稷神",
                "description": "允许建造者在帝国内任意平原地形改良农场。所有的农场/种植园额外+3粮食，1生产力与2信仰/+1粮食，3生产力与2文化值。种植园与农场为相邻区域提供大量加成。"
              },
              {
